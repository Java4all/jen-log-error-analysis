# -----------------------------------------------------------------------------
# Jenkins Performance Analyzer -- Environment Variables
# Copy to .env and fill in your values.
# -----------------------------------------------------------------------------

# -- Ports ---------------------------------------------------------------------
FRONTEND_PORT=3000
API_PORT=8000
OLLAMA_PORT=11434

# -- AI Provider ---------------------------------------------------------------
# Options: anthropic | ollama | private
AI_PROVIDER=anthropic

# Anthropic Cloud
ANTHROPIC_API_KEY=sk-ant-...

# -- GitHub --------------------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -- GPU / Ollama --------------------------------------------------------------
NVIDIA_GPU_COUNT=1

# Model to auto-pull: codellama:13b | codellama:7b | mistral:7b | llama3:8b
OLLAMA_MODEL=codellama:13b

OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1

# -- Isolation mode -----------------------------------------------------------
# -- Multi-arch build settings ------------------------------------------------
# docker buildx is used to build for linux/amd64 AND linux/arm64 simultaneously.
# Run "make buildx-setup" (or ".\make.ps1 buildx-setup") once per build machine
# to create the required builder. Requires Docker >= 20.10 and BuildKit enabled.
DOCKER_BUILDKIT=1

# -- Pre-built image registry (for restricted / air-gapped environments) ------
# Set IMAGE_REGISTRY to push/pull from a private registry.
# Leave empty to use local image names only (docker save/load workflow).
IMAGE_REGISTRY=
IMAGE_REPO=jenkins-analyzer
IMAGE_TAG=latest
# Pull policy when using docker-compose.prebuilt.yml:
#   if_not_present (default) -- only pull if image not already local
#   always                   -- always pull from registry on up
IMAGE_PULL_POLICY=if_not_present

# Block public cloud services (Anthropic API, public github.com).
# GitHub Enterprise, private AI, and on-prem resources remain accessible.
# Legacy var ISOLATED_MODE=true also works.
PRIVATE_ONLY_MODE=false

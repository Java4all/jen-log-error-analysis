# -----------------------------------------------------------------------------
# Jenkins Performance Analyzer -- Environment Variables
# Copy to .env and fill in your values.
# -----------------------------------------------------------------------------

# -- Ports ---------------------------------------------------------------------
FRONTEND_PORT=3000
API_PORT=8000
OLLAMA_PORT=11434

# -- AI Provider ---------------------------------------------------------------
# Options: anthropic | ollama | private
AI_PROVIDER=anthropic

# Anthropic Cloud
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (used when AI_PROVIDER=ollama)
# OLLAMA_BASE_URL defaults to http://ollama:11434 (the compose service name)
# For native Ollama on Mac M1/M2/M3 with Metal GPU (recommended for performance):
#   1. brew install ollama && ollama serve
#   2. Set OLLAMA_BASE_URL=http://host.docker.internal:11434
#   3. Run without ollama profile: make up-prebuilt (no ollama container)
# Docker Desktop on Mac has no Metal GPU passthrough -- native is ~8-10x faster.
OLLAMA_BASE_URL=http://ollama:11434
#OLLAMA_BASE_URL=http://host.docker.internal:11434  # uncomment for native Ollama on Mac
OLLAMA_MODEL=codellama:13b
OLLAMA_TIMEOUT=120          # per-request timeout for normal calls
#OLLAMA_TIMEOUT_SYNTHESIS=600 # synthesis timeout (set in config.yaml ai.ollama.synthesis_timeout)

# Private / OpenAI-compatible endpoint (used when AI_PROVIDER=private)
# e.g. llama.cpp server, vLLM, LM Studio, Azure OpenAI
PRIVATE_AI_BASE_URL=http://your-ai-server:8080/v1
PRIVATE_AI_API_KEY=
PRIVATE_AI_MODEL=codellama-13b-instruct

# -- GitHub --------------------------------------------------------------------
GITHUB_TOKEN=ghp_...
# Options: public | private (GitHub Enterprise)
GITHUB_TYPE=public
# GitHub Enterprise API URL -- preferred way to configure GHE
# Format: https://github.mycompany.com/api/v3
# Can also be set in UI: Config tab -> GitHub -> API URL field
#GITHUB_API_URL=https://github.mycompany.com/api/v3
# Legacy: GITHUB_ENTERPRISE_URL auto-derives the API URL (still works)
GITHUB_ENTERPRISE_URL=

# -- GPU / Ollama --------------------------------------------------------------
NVIDIA_GPU_COUNT=1

# Model to auto-pull: codellama:13b | codellama:7b | mistral:7b | llama3:8b
OLLAMA_MODEL=codellama:13b

# IMPORTANT: must be 0.0.0.0 so other containers can connect to Ollama.
# Setting this to localhost or 127.0.0.1 will block all inter-container traffic.
OLLAMA_HOST=0.0.0.0

OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=1

# -- Isolation mode -----------------------------------------------------------
# -- Multi-arch build settings ------------------------------------------------
# docker buildx is used to build for linux/amd64 AND linux/arm64 simultaneously.
# Run "make buildx-setup" (or ".\make.ps1 buildx-setup") once per build machine
# to create the required builder. Requires Docker >= 20.10 and BuildKit enabled.
DOCKER_BUILDKIT=1

# -- Pre-built image registry (for restricted / air-gapped environments) ------
# Set IMAGE_REGISTRY to push/pull from a private registry.
# Leave empty to use local image names only (docker save/load workflow).
IMAGE_REGISTRY=
IMAGE_REPO=jenkins-analyzer
IMAGE_TAG=latest
# Pull policy when using docker-compose.prebuilt.yml:
#   if_not_present (default) -- only pull if image not already local
#   always                   -- always pull from registry on up
IMAGE_PULL_POLICY=if_not_present

# SSL verification -- set false for corporate environments with custom CA / self-signed certs
# VERIFY_SSL=false        disables SSL for ALL outbound calls (GitHub + private AI)
# GITHUB_VERIFY_SSL=false disables SSL for GitHub only
#VERIFY_SSL=false
#GITHUB_VERIFY_SSL=false

# GitHub Enterprise API URL -- required for GitHub Enterprise connections
# Format: https://github.mycompany.com/api/v3
# If GITHUB_ENTERPRISE_URL is set, api/v3 is appended automatically
#GITHUB_API_URL=https://github.mycompany.com/api/v3

# Block public cloud services (Anthropic API, public github.com).
# GitHub Enterprise, private AI, and on-prem resources remain accessible.
# Legacy var ISOLATED_MODE=true also works.
PRIVATE_ONLY_MODE=false
ISOLATED_MODE=false
